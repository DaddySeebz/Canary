# Clerk auth for /login, /signup, and the protected /projects workspace
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Durable storage for Vercel deployments
DATABASE_URL=postgresql://user:password@host.neon.tech/canary?sslmode=require
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# Optional: public read-only demo workspace
CANARY_PUBLIC_DEMO_ENABLED=true

# Optional: enable AI rule chat
OPENROUTER_API_KEY=sk-or-your-key-here
